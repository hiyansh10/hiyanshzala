<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HZ-2026 // Hiyansh Zala — Personal Blueprint</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #050505;
    --white: #f0f0f0;
    --dim: #888;
    --faint: rgba(240,240,240,0.06);
    --line: rgba(240,240,240,0.15);
    --line-bright: rgba(240,240,240,0.35);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'IBM Plex Mono', monospace;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* ── BLUEPRINT GRID ── */
  .bp-grid {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    animation: gridFade 2s ease forwards 0.3s;
  }
  @keyframes gridFade { to { opacity: 1; } }

  .bp-grid svg { width: 100%; height: 100%; }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 52px;
    border-bottom: 1px solid var(--line);
    background: rgba(5,5,5,0.92);
    backdrop-filter: blur(8px);
  }

  .nav-logo {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--dim);
  }

  .nav-logo span { color: var(--white); }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-links a {
    display: block;
    padding: 0.3rem 0.75rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--dim);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.2s;
  }

  .nav-links a:hover {
    color: var(--white);
    border-color: var(--line-bright);
    background: var(--faint);
  }

  .nav-rev {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    color: var(--dim);
    letter-spacing: 0.1em;
  }

  /* ── HERO ── */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 80px 4rem 4rem;
    overflow: hidden;
  }

  .hero-corner {
    position: absolute;
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    color: var(--dim);
    line-height: 1.6;
  }
  .hero-corner.tl { top: 68px; left: 2rem; }
  .hero-corner.tr { top: 68px; right: 2rem; text-align: right; }
  .hero-corner.bl { bottom: 2rem; left: 2rem; }
  .hero-corner.br { bottom: 2rem; right: 2rem; text-align: right; }

  /* Blueprint bracket corners */
  .bracket {
    position: absolute;
    width: 24px; height: 24px;
    pointer-events: none;
  }
  .bracket.tl { top: 60px; left: 1rem; border-top: 1px solid var(--line-bright); border-left: 1px solid var(--line-bright); }
  .bracket.tr { top: 60px; right: 1rem; border-top: 1px solid var(--line-bright); border-right: 1px solid var(--line-bright); }
  .bracket.bl { bottom: 1rem; left: 1rem; border-bottom: 1px solid var(--line-bright); border-left: 1px solid var(--line-bright); }
  .bracket.br { bottom: 1rem; right: 1rem; border-bottom: 1px solid var(--line-bright); border-right: 1px solid var(--line-bright); }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .pixel-frame {
    position: relative;
    display: inline-block;
  }

  .pixel-frame::before,
  .pixel-frame::after {
    content: '';
    position: absolute;
    inset: -12px;
    border: 1px solid var(--line);
    pointer-events: none;
  }

  .pixel-frame::after {
    inset: -20px;
    border: 1px solid rgba(240,240,240,0.07);
  }

  .pixel-img {
    width: 260px;
    height: 260px;
    object-fit: contain;
    image-rendering: pixelated;
    filter: contrast(1.05);
  }

  .pixel-label {
    margin-top: 1.5rem;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    text-align: center;
  }

  /* Measurement lines */
  .meas-h {
    position: absolute;
    bottom: 2.5rem;
    left: 0; right: 0;
    display: flex;
    align-items: center;
    gap: 0;
    pointer-events: none;
  }
  .meas-h::before, .meas-h::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .meas-h span {
    padding: 0 0.5rem;
    font-size: 0.5rem;
    color: var(--dim);
    letter-spacing: 0.1em;
  }

  .hero-right { position: relative; }

  .eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--dim);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--dim);
  }

  .hero-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--dim);
    margin-bottom: 2.5rem;
    line-height: 1.5;
  }

  .tech-specs {
    border: 1px solid var(--line);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.4rem 1.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    position: relative;
  }
  .tech-specs::before {
    content: 'TECH SPEC';
    position: absolute;
    top: -0.45rem;
    left: 1rem;
    background: var(--black);
    padding: 0 0.4rem;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--dim);
  }
  .spec-key { color: var(--dim); }
  .spec-val { color: var(--white); }
  .spec-dot {
    display: inline-block;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--white);
    margin-right: 0.5rem;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .btn-blueprint {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1.8rem;
    border: 1px solid var(--white);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--white);
    text-decoration: none;
    background: transparent;
    cursor: crosshair;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .btn-blueprint::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--white);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .btn-blueprint:hover { color: var(--black); }
  .btn-blueprint:hover::before { transform: translateX(0); }
  .btn-blueprint span { position: relative; z-index: 1; }

  /* ── SECTIONS COMMON ── */
  section {
    position: relative;
    z-index: 2;
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-wrap {
    border-top: 1px solid var(--line);
    position: relative;
  }

  .sec-number {
    position: absolute;
    top: -0.5rem;
    right: 2rem;
    background: var(--black);
    padding: 0 0.5rem;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
  }

  .sec-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 3rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .sec-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  /* ── IDENTITY ── */
  .identity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .spec-sheet {
    border: 1px solid var(--line);
    padding: 1.5rem;
    position: relative;
  }
  .spec-sheet-title {
    position: absolute;
    top: -0.5rem;
    left: 1rem;
    background: var(--black);
    padding: 0 0.4rem;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
  }
  .spec-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 0.5rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--faint);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
  }
  .spec-row:last-child { border-bottom: none; }
  .spec-row .k { color: var(--dim); }
  .spec-row .v { color: var(--white); }

  .identity-bio {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(240,240,240,0.75);
  }

  .bio-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .bio-label::after { content: ''; flex: 1; height: 1px; background: var(--line); }

  /* ── STATS ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .stat-panel {
    background: var(--black);
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .stat-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--line-bright);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s ease;
  }
  .stat-panel.visible::before { transform: scaleX(1); }

  .stat-label {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    margin-bottom: 1rem;
  }
  .stat-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-sub {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--dim);
  }

  /* ── TIMELINE ── */
  .timeline {
    position: relative;
    padding-left: 3rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--line);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.5s ease;
  }
  .timeline-item.visible { opacity: 1; transform: translateX(0); }

  .timeline-node {
    position: absolute;
    left: -2.7rem;
    top: 0.35rem;
    width: 10px; height: 10px;
    border: 1px solid var(--white);
    background: var(--black);
    animation: nodePulse 3s ease-in-out infinite;
  }
  @keyframes nodePulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(240,240,240,0.3); }
    50% { box-shadow: 0 0 0 6px rgba(240,240,240,0); }
  }

  .timeline-year {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    margin-bottom: 0.4rem;
  }
  .timeline-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .timeline-desc {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--dim);
    line-height: 1.7;
  }

  /* ── PROJECTS ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    border: 1px solid var(--line);
    padding: 1.5rem;
    position: relative;
    transition: border-color 0.3s;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease, border-color 0.3s;
  }
  .project-card.visible { opacity: 1; transform: translateY(0); }
  .project-card:hover { border-color: var(--line-bright); }

  .project-card::before {
    content: '';
    position: absolute;
    top: -1px; left: 1.5rem; right: 1.5rem;
    height: 1px;
    background: var(--white);
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }
  .project-card:hover::before { transform: scaleX(1); }

  .project-id {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    margin-bottom: 1rem;
    display: flex;
    justify-content: space-between;
  }
  .project-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .status-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--white);
    animation: pulse 2s ease-in-out infinite;
  }

  .project-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .project-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--dim);
    border-top: 1px solid var(--faint);
    padding-top: 0.75rem;
    margin-top: 0.75rem;
  }
  .project-meta span b { color: var(--white); margin-right: 0.4rem; }

  /* ── CONTACT ── */
  .contact-terminal {
    border: 1px solid var(--line);
    padding: 2rem;
    position: relative;
  }
  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .terminal-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--line-bright);
  }
  .terminal-title {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    margin-left: auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .contact-item {
    border: 1px solid var(--faint);
    padding: 1rem 1.25rem;
    transition: border-color 0.2s;
  }
  .contact-item:hover { border-color: var(--line); }
  .contact-channel {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--dim);
    margin-bottom: 0.5rem;
  }
  .contact-value {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--white);
    word-break: break-all;
  }
  .contact-value a { color: inherit; text-decoration: none; }
  .contact-value a:hover { text-decoration: underline; }

  /* ── FOOTER ── */
  footer {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--line);
    padding: 3rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }
  .footer-quote {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-style: italic;
    color: rgba(240,240,240,0.5);
    max-width: 500px;
    line-height: 1.6;
  }
  .footer-right {
    text-align: right;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--dim);
    line-height: 2;
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    #hero { padding: 80px 2rem 3rem; }
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; text-align: center; }
    .hero-left { order: -1; }
    .eyebrow { justify-content: center; }
    .tech-specs { max-width: 340px; margin: 0 auto 2rem; }
    .btn-blueprint { margin: 0 auto; }
    section { padding: 4rem 2rem; }
    .identity-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .projects-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
    footer { flex-direction: column; align-items: flex-start; }
    .footer-right { text-align: left; }
    nav { padding: 0 1rem; }
    .nav-links a { padding: 0.3rem 0.4rem; font-size: 0.6rem; }
    .nav-rev { display: none; }
  }

  @media (max-width: 600px) {
    .hero-name { font-size: 2.2rem; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .hero-corner.tr, .hero-corner.br { display: none; }
  }
</style>
</head>
<body>

<!-- Blueprint Grid Background -->
<div class="bp-grid" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
    <defs>
      <pattern id="smallGrid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(240,240,240,0.04)" stroke-width="0.5"/>
      </pattern>
      <pattern id="bigGrid" width="200" height="200" patternUnits="userSpaceOnUse">
        <rect width="200" height="200" fill="url(#smallGrid)"/>
        <path d="M 200 0 L 0 0 0 200" fill="none" stroke="rgba(240,240,240,0.08)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#bigGrid)"/>
