    <line x1="33%" y1="0" x2="33%" y2="100%" stroke="rgba(240,240,240,0.03)" stroke-width="1" stroke-dasharray="4,8"/>
    <line x1="66%" y1="0" x2="66%" y2="100%" stroke="rgba(240,240,240,0.03)" stroke-width="1" stroke-dasharray="4,8"/>
